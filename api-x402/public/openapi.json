{
  "openapi": "3.1.0",
  "info": {
    "title": "ETHGlobal Search API (Paid)",
    "version": "1.0.0",
    "description": "Search ETHGlobal hackathon projects, sponsor bounties, and prize winners across all events from ETHWaterloo to present.",
    "x-guidance": "Use this API to search ETHGlobal hackathon data. All endpoints are POST and require $0.01 USDC on Base mainnet via x402. Typical workflow: (1) POST /api/prizes to find sponsor bounties and requirements for a specific event. (2) POST /api/projects to find winning projects filtered by event, sponsor, or keyword. (3) POST /api/sponsors to look up the exact sponsor name when unsure. Event names must be exact — use the full name like 'ETHGlobal Taipei' or 'HackMoney 2026'."
  },
  "servers": [
    { "url": "http://localhost:3002" }
  ],
  "paths": {
    "/api/sponsors": {
      "post": {
        "operationId": "getSponsors",
        "summary": "List sponsor names",
        "description": "Returns sponsor names. Use this to find the exact sponsor name to pass to /api/prizes or /api/projects.",
        "x-payment-info": {
          "price": { "mode": "fixed", "currency": "USD", "amount": "0.01" },
          "protocols": [{ "x402": {} }]
        },
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keyword": {
                    "type": "string",
                    "description": "Partial name match to narrow results (e.g. 'uniswap')"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of sponsor names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sponsors": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "402": { "description": "Payment Required" }
        }
      }
    },
    "/api/events": {
      "post": {
        "operationId": "getEvents",
        "summary": "List all hackathon events",
        "description": "Returns all ETHGlobal events sorted by most recent first.",
        "x-payment-info": {
          "price": { "mode": "fixed", "currency": "USD", "amount": "0.01" },
          "protocols": [{ "x402": {} }]
        },
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "events": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "url": { "type": "string" },
                          "start_date": { "type": "string" },
                          "end_date": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "402": { "description": "Payment Required" }
        }
      }
    },
    "/api/prizes": {
      "post": {
        "operationId": "getPrizes",
        "summary": "Get sponsor bounties for an event",
        "description": "Returns bounties grouped by sponsor with descriptions, qualifications, and resource links. At least one of event or sponsor is required.",
        "x-payment-info": {
          "price": { "mode": "fixed", "currency": "USD", "amount": "0.01" },
          "protocols": [{ "x402": {} }]
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event": {
                    "type": "string",
                    "description": "Exact event name (e.g. 'ETHGlobal Taipei', 'HackMoney 2026'). Required if sponsor not provided."
                  },
                  "sponsor": {
                    "type": "string",
                    "description": "Exact sponsor name (e.g. 'Uniswap Foundation', 'World'). Required if event not provided."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bounties grouped by sponsor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "about": { "type": "string" },
                          "docs": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": { "type": "string" },
                                "url": { "type": "string" }
                              }
                            }
                          },
                          "prizes": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "title": { "type": "string" },
                                "description": { "type": "string" },
                                "qualifications": { "type": "string" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad Request — at least one of event or sponsor is required" },
          "402": { "description": "Payment Required" }
        }
      }
    },
    "/api/projects": {
      "post": {
        "operationId": "searchProjects",
        "summary": "Search hackathon projects",
        "description": "Search projects by event, keyword, sponsor, or prize won. Returns title, tagline, links, and prizes won.",
        "x-payment-info": {
          "price": { "mode": "fixed", "currency": "USD", "amount": "0.01" },
          "protocols": [{ "x402": {} }]
        },
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event": {
                    "type": "string",
                    "description": "Exact event name (e.g. 'ETHGlobal Taipei')"
                  },
                  "keyword": {
                    "type": "string",
                    "description": "Searches title, tagline, description, and how_its_made fields"
                  },
                  "sponsor": {
                    "type": "string",
                    "description": "Exact sponsor name — filters to projects that won a prize from this sponsor"
                  },
                  "prize": {
                    "type": "string",
                    "description": "Partial prize title match (e.g. 'Finalist', 'Best Mini App')"
                  },
                  "pool": {
                    "type": "boolean",
                    "default": false,
                    "description": "Set to true to include pool prize projects when filtering by sponsor"
                  },
                  "include": {
                    "type": "string",
                    "description": "Comma-separated optional fields to include: description, how_its_made"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 30,
                    "maximum": 100,
                    "description": "Max results"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of matching projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "projects": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": { "type": "string" },
                          "url": { "type": "string" },
                          "tagline": { "type": "string" },
                          "github": { "type": "string" },
                          "live_demo": { "type": "string" },
                          "hackathon": { "type": "string" },
                          "prizes_won": { "type": "array", "items": { "type": "string" } }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "402": { "description": "Payment Required" }
        }
      }
    }
  }
}
